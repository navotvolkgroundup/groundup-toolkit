# GroundUp Toolkit - Cron Jobs
#
# Set TOOLKIT_ROOT to your installation directory before installing:
#   export TOOLKIT_ROOT=/path/to/groundup-toolkit
#   envsubst < cron/crontab.example | crontab -
#
# Or edit TOOLKIT_ROOT below manually, then:
#   crontab cron/crontab.example

SHELL=/bin/bash
PATH=/usr/local/sbin:/usr/local/bin:/usr/sbin:/usr/bin:/sbin:/bin
TOOLKIT_ROOT=/path/to/groundup-toolkit
MAILTO=""

# Uses load-env.sh to export only the secrets each job needs,
# instead of sourcing the entire .env into every process.
# See scripts/load-env.sh for the per-job variable mappings.
# Note: if env vars are already injected (e.g. container environment),
# load-env.sh will skip .env and use the existing environment.

# Meeting reminders - every 5 minutes
# Sends WhatsApp reminders 10-15 min before meetings
*/5 * * * * $TOOLKIT_ROOT/scripts/load-env.sh meeting-reminders -- $TOOLKIT_ROOT/skills/meeting-reminders/meeting-reminders reminders >> /var/log/meeting-reminders.log 2>&1

# Meeting bot - process recordings every 2 hours
0 */2 * * * $TOOLKIT_ROOT/scripts/load-env.sh meeting-bot -- $TOOLKIT_ROOT/skills/meeting-bot/meeting-bot >> /var/log/meeting-bot.log 2>&1

# Meeting auto-join - every minute
*/1 * * * * $TOOLKIT_ROOT/scripts/load-env.sh meeting-bot -- $TOOLKIT_ROOT/skills/meeting-bot/meeting-auto-join >> /var/log/meeting-auto-join.log 2>&1

# Email-to-deal automation - every 10 minutes
# Scans inbox for pitch decks / deal emails and creates HubSpot deals
*/10 * * * * $TOOLKIT_ROOT/scripts/load-env.sh email-to-deal -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/scripts/email-to-deal-automation.py >> /var/log/email-to-deal.log 2>&1

# Health check - every 15 minutes
*/15 * * * * $TOOLKIT_ROOT/scripts/health-check.sh >> /var/log/toolkit-health.log 2>&1

# Scheduled tasks (Shabbat-aware) - every 2 hours
0 */2 * * * $TOOLKIT_ROOT/scripts/run-scheduled.sh >> /var/log/scheduled.log 2>&1

# Founder Scout - daily scan at 7:00 AM UTC
0 7 * * * $TOOLKIT_ROOT/scripts/load-env.sh founder-scout -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/skills/founder-scout/scout.py scan >> /var/log/founder-scout.log 2>&1

# Founder Scout - weekly briefing on Sunday at 8:00 AM UTC
0 8 * * 0 $TOOLKIT_ROOT/scripts/load-env.sh founder-scout -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/skills/founder-scout/scout.py briefing >> /var/log/founder-scout.log 2>&1

# Founder Scout - watchlist re-scan on Wed/Sat at 14:00 UTC
0 14 * * 3,6 $TOOLKIT_ROOT/scripts/load-env.sh founder-scout -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/skills/founder-scout/scout.py watchlist-update >> /var/log/founder-scout.log 2>&1

# Keep on Radar - monthly review on 15th at 9:00 AM UTC
0 9 15 * * $TOOLKIT_ROOT/scripts/load-env.sh keep-on-radar -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/skills/keep-on-radar/radar.py review >> /var/log/keep-on-radar.log 2>&1

# Keep on Radar - check replies every 2 hours
0 */2 * * * $TOOLKIT_ROOT/scripts/load-env.sh keep-on-radar -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/skills/keep-on-radar/radar.py check-replies >> /var/log/keep-on-radar.log 2>&1

# Portfolio deep scan - weekly on Mondays at 8:00 AM UTC
0 8 * * 1 $TOOLKIT_ROOT/scripts/load-env.sh portfolio-deep-scan -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/scripts/portfolio_monitor.py deep-scan >> /var/log/portfolio-monitor.log 2>&1

# Cron watchdog - every 30 minutes
# Alerts via WhatsApp if any scheduled job stops running
*/30 * * * * $TOOLKIT_ROOT/scripts/load-env.sh cron-watchdog -- $TOOLKIT_ROOT/.venv/bin/python3 $TOOLKIT_ROOT/scripts/cron-watchdog.py check >> /var/log/cron-watchdog.log 2>&1

# SQLite backup - daily at 3:00 AM UTC (before maintenance)
0 3 * * * $TOOLKIT_ROOT/scripts/backup-db.sh >> /var/log/daily-maintenance.log 2>&1

# Daily maintenance - system updates at 4:00 AM UTC
0 4 * * * $TOOLKIT_ROOT/scripts/daily-maintenance.sh >> /var/log/daily-maintenance.log 2>&1

# NOTE: Log files are written to /var/log/. Make sure the cron user has
# write access, or change paths to e.g. $TOOLKIT_ROOT/logs/
