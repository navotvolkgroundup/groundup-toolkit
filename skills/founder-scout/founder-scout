#!/bin/bash

SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
SCRIPT="$SCRIPT_DIR/scout.py"

# Safe .env loading (no shell execution)
if [ -f "$HOME/.env" ]; then
    while IFS='=' read -r key value; do
        [[ -z "$key" || "$key" =~ ^[[:space:]]*# ]] && continue
        key=$(echo "$key" | xargs)
        [[ "$key" =~ ^[A-Za-z_][A-Za-z_0-9]*$ ]] && export "$key=$value"
    done < "$HOME/.env"
fi

ACTION="${1:-scan}"

case "$ACTION" in
    scan)
        /usr/bin/python3 "$SCRIPT" scan
        ;;

    briefing)
        /usr/bin/python3 "$SCRIPT" briefing
        ;;

    watchlist-update)
        /usr/bin/python3 "$SCRIPT" watchlist-update
        ;;

    status)
        /usr/bin/python3 "$SCRIPT" status
        ;;

    add)
        NAME="${2:-}"
        LINKEDIN_URL="${3:-}"
        if [ -z "$NAME" ]; then
            echo "Usage: founder-scout add <name> [linkedin_url]"
            exit 1
        fi
        /usr/bin/python3 "$SCRIPT" add "$NAME" "$LINKEDIN_URL"
        ;;

    dismiss)
        PERSON_ID="${2:-}"
        if [ -z "$PERSON_ID" ]; then
            echo "Usage: founder-scout dismiss <id>"
            exit 1
        fi
        /usr/bin/python3 "$SCRIPT" dismiss "$PERSON_ID"
        ;;

    sync-hubspot)
        /usr/bin/python3 "$SCRIPT" sync-hubspot
        ;;

    approach)
        NAME="${2:-}"
        if [ -z "$NAME" ]; then
            echo "Usage: founder-scout approach <name>"
            exit 1
        fi
        shift
        /usr/bin/python3 "$SCRIPT" approach "$@"
        ;;

    approach-id)
        PERSON_ID="${2:-}"
        if [ -z "$PERSON_ID" ]; then
            echo "Usage: founder-scout approach-id <id>"
            exit 1
        fi
        /usr/bin/python3 "$SCRIPT" approach-id "$PERSON_ID"
        ;;

    github-scan)
        /usr/bin/python3 "$SCRIPT" github-scan
        ;;

    registrar-scan)
        /usr/bin/python3 "$SCRIPT" registrar-scan
        ;;

    retention-update)
        /usr/bin/python3 "$SCRIPT" retention-update
        ;;

    acquisition-scan)
        /usr/bin/python3 "$SCRIPT" acquisition-scan
        ;;

    domain-scan)
        /usr/bin/python3 "$SCRIPT" domain-scan
        ;;

    event-scan)
        /usr/bin/python3 "$SCRIPT" event-scan
        ;;

    score-update)
        /usr/bin/python3 "$SCRIPT" score-update
        ;;

    digest)
        /usr/bin/python3 "$SCRIPT" digest
        ;;

    *)
        echo "Usage: founder-scout [scan|briefing|watchlist-update|github-scan|registrar-scan|retention-update|acquisition-scan|domain-scan|event-scan|score-update|digest|status|add|dismiss|sync-hubspot|approach|approach-id]"
        exit 1
        ;;
esac
